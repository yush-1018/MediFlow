rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper: Get user data from users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper: Check if user is an admin
    function isCmsAdmin() {
      return isSignedIn() && getUserData().role == 'cms_admin';
    }
    
    // Helper: Check if user is head of a specific facility
    function isFacilityHead(facilityId) {
      return isSignedIn() && 
             getUserData().role == 'facility_head' && 
             getUserData().facilityId == facilityId;
    }

    // --- Rules for Users Collection ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Users should be managed via Admin SDK/Cloud Functions for safety
    }

    // --- Rules for Facilities Collection ---
    match /facilities/{facilityId} {
      allow read: if isSignedIn();
      allow write: if isCmsAdmin(); 
      
      // Subcollection: Stocks
      match /stocks/{stockId} {
        allow read: if isCmsAdmin() || isFacilityHead(facilityId);
        allow write: if isCmsAdmin() || isFacilityHead(facilityId);
      }
      
      // Subcollection: Usage Logs
      match /usage_logs/{logId} {
        allow read: if isCmsAdmin() || isFacilityHead(facilityId);
        allow create: if isFacilityHead(facilityId);
        allow update, delete: if isCmsAdmin();
      }
    }

    // --- Rules for Requests Collection ---
    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && getUserData().role == 'facility_head';
      allow update: if isCmsAdmin(); // Only Admin can approve/reject
      allow delete: if false;
    }
  }
}
